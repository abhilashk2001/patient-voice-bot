# =========================
# Pretty Good AI Challenge
# =========================
# Authorized assessment number. The app validates this and refuses to call
# any other number. Do not change.
TARGET_PHONE_NUMBER=+18054398008

# The single caller number used for ALL test calls (E.164), e.g. +13334445555.
CALLER_PHONE_NUMBER=+1XXXXXXXXXX

# Your REAL registered PGAI patient identity, used to verify on every call.
# The scenario/persona varies per call, but name + DOB stay constant so the
# clinic can verify the caller and proceed. (PII — keep in .env, not committed.)
PATIENT_NAME=Your Full Name
PATIENT_DOB=DD Month YYYY

# The phone number ON FILE in your PGAI test account (what the patient states to
# verify). May DIFFER from the Twilio caller number. E.164, e.g. +15551234567.
PATIENT_PHONE_ON_FILE=+1XXXXXXXXXX

# =========================
# Telephony Provider (Twilio)
# =========================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Public webhook URL for Twilio voice callbacks (from ngrok).
# Example: https://abc123.ngrok-free.app/voice
PUBLIC_WEBHOOK_URL=https://your-public-url.example.com/voice

# Public WebSocket URL for Twilio Media Streams (from ngrok).
# Example: wss://abc123.ngrok-free.app/media
PUBLIC_MEDIA_STREAM_URL=wss://your-public-url.example.com/media

# =========================
# OpenAI Realtime
# =========================
# Speech-to-speech model drives the patient conversation.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-realtime

# Realtime voice for the patient (varied per scenario for realism).
REALTIME_VOICE=alloy

# Local port the media WebSocket server binds to (ngrok forwards here).
MEDIA_SERVER_PORT=8080

# =========================
# App Settings
# =========================
# Output directory for call recordings, transcripts, and metadata.
CALL_OUTPUT_DIR=./calls

# Scenario file path.
SCENARIOS_FILE=./scenarios/scenarios.json

# Maximum call duration in seconds (runaway backstop). Good calls are 1-3 min.
MAX_CALL_SECONDS=180

# Number of recent conversation turns considered for context.
RECENT_TURNS_LIMIT=6

# Dry-run mode: renders the prompt + runs guards, places no real call.
DRY_RUN=false
